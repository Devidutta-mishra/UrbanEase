rules_version = '2';

// UrbanEase Firestore security rules.
//
// Roles live on /users/{uid}.role ("owner" | "bachelor" | "admin").
// These rules enforce the Owner -> Admin -> User verification workflow at the
// data layer, so UI checks are never the only line of defence.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    // ---- Users ----------------------------------------------------------
    // Contact details are shared between matched owners/bachelors, so any
    // signed-in user may read profiles. A user may only write their own doc.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ---- Properties -----------------------------------------------------
    match /properties/{propertyId} {
      allow read: if isSignedIn();

      // Owners create only their own listings.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Owners may update their own listing; admins may moderate any listing.
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ---- Booking requests ----------------------------------------------
    match /requests/{requestId} {
      // Visible to the bachelor who applied, the owner of the property, or admin.
      allow read: if isAdmin() ||
        (isSignedIn() && (
          resource.data.bachelorId == request.auth.uid ||
          resource.data.ownerId == request.auth.uid
        ));

      // A bachelor creates a request only for themselves.
      allow create: if isSignedIn() && request.resource.data.bachelorId == request.auth.uid;

      // Either party (or admin) may update status; ownership cannot change.
      allow update: if isAdmin() ||
        (isSignedIn() && (
          resource.data.bachelorId == request.auth.uid ||
          resource.data.ownerId == request.auth.uid
        ));

      allow delete: if isAdmin();
    }
  }
}
